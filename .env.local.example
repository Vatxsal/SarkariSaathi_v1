# Copy this file to .env.local and fill in your actual keys.
# NEVER commit .env.local to git — it is already in .gitignore.

# Gemini API Key
# Get it free at: https://aistudio.google.com → Get API Key → Create API Key
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Project URL
# Find at: supabase.com → Your Project → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous (public) key
# Find at: supabase.com → Your Project → Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Base URL for the app (use localhost for development)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
